---
import Core from "../../layouts/Core.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("projects");

  return posts.map((project) => ({
    params: { project: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Core title={`${project.data.title} | Huskey.cc Projects`}>
  <section class="p-16 lg:p-24 min-h-[75vh]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4 sticky lg:top-20 self-start">
        <div
          class="text-xs sm:text-sm font-mono text-gray-400 uppercase tracking-wider"
        >
          <span class="mx-1 opacity-60">/</span>
          <a
            href="/projects"
            class="hover:text-white transition-colors duration-200"
          >
            projects
          </a>

          <span class="mx-1 opacity-60">/</span>

          <a
            href={`/projects/${new Date(project.data.date).getFullYear()}`}
            class="hover:text-white transition-colors duration-200"
          >
            {new Date(project.data.date).getFullYear()}
          </a>

          <span class="mx-1 opacity-60">/</span>

          <span class="">
            {project.slug.split("/").pop()}
          </span>
        </div>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100 leading-tight wrap-break-word"
        >
          {project.data.title}
        </h2>
        <p class="mt-6 text-sm font-mono text-gray-300">
          {
            new Date(project.data.date).toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            })
          }
          {" - "}
          {
            project.data.dateEnd
              ? new Date(project.data.dateEnd).toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })
              : "OnGoing"
          }
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            project.data.tech?.map((tech) => {
              const [label, hex] = tech.split("#");
              const color = hex ? `#${hex}` : "#111827";
              return (
                <span
                  class="px-2.5 py-1 text-xs font-medium text-white rounded-md"
                  style={{ backgroundColor: `${color}50` }}
                >
                  {label}
                </span>
              );
            })
          }
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            project.data.tags?.map((tag) => (
              <span class="px-2.5 py-1 text-xs font-medium text-gray-300 bg-gray-700/50 rounded-md">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
      <div class="lg:col-span-8">
        <div
          class="relative p-6 sm:p-8 md:p-10 bg-gray-800/20 rounded-xl sm:rounded-2xl backdrop-blur-sm transition-all duration-300"
        >
          <article
            class="prose prose-invert max-w-none
								   prose-headings:text-gray-100
								   prose-p:text-gray-300
								   prose-strong:text-white
								   prose-a:text-blue-400
								   prose-a:no-underline hover:prose-a:underline
								   prose-code:text-pink-400
								   prose-pre:bg-gray-900/70
								   prose-pre:rounded-xl"
          >
            <Content />
          </article>
        </div>
      </div>
    </div>
  </section>
</Core>
