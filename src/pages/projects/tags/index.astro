---
import Core from "../../../layouts/Core.astro";
import Breadcrumb from "../../../components/core/Breadcrumb.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

const tagMap = new Map<string, number>();

for (const project of projects) {
  for (const tag of project.data.tags || []) {
    const [name] = tag.split("#");
    const key = name;

    tagMap.set(key, (tagMap.get(key) || 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<Core title="Project Tags | Huskey.cc">
  <section class="p-8 sm:p-12 md:p-16 lg:p-24">
    <Breadcrumb
      items={[
        { label: "projects", href: "/projects" },
        { label: "tags", href: "/projects/tags" },
      ]}
    />
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-100">
      Project Tags
    </h1>

    <p class="mt-4 text-white/50 max-w-2xl">
      Browse all types of projects I've worked on, categorized by tags. Click on
      a tag to see all projects associated with it. This is a great way to
      explore my work based on specific technologies, themes, or topics that
      interest you.
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      {
        tags.map(([tag, count]) => (
          <a
            href={`/projects/tags/${tag.toLowerCase()}`}
            class="px-3 py-2 rounded-lg
              bg-gray-800/20 border border-white/5
              text-white/70 text-sm sm:text-base
              transition-all duration-300

              hover:bg-gray-800/40
              hover:border-white/10
              hover:text-white"
          >
            {tag} <span class="text-white/40">({count})</span>
          </a>
        ))
      }
    </div>
  </section>
</Core>
