---
import Core from "../../../layouts/Core.astro";
import { getCollection } from "astro:content";
import Breadcrumb from "../../../components/core/Breadcrumb.astro";
import ProjectCard from "../../../components/ProjectCard.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  const tags = new Set<string>();

  for (const project of projects) {
    for (const tag of project.data.tags || []) {
      tags.add(tag.split("#")[0].toLowerCase());
    }
  }

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      projects: projects
        .filter((project) =>
          (project.data.tags || []).some(
            (t) => t.split("#")[0].toLowerCase() === tag,
          ),
        )
        .sort(
          (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
        ),
    },
  }));
}

const { tag, projects } = Astro.props;
---

<Core title={`${tag} Projects | Huskey.cc`}>
  <section class="p-8 sm:p-12 md:p-16 lg:p-24 min-h-[70vh]">
    <!-- Header -->
    <div class="mb-10">
      <Breadcrumb
        items={[
          { label: "projects", href: "/projects" },
          { label: "tags", href: "/projects/tags" },
          { label: tag, href: `/projects/tags/${tag}` },
        ]}
      />

      <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold text-gray-100">
        {tag.charAt(0).toUpperCase() + tag.slice(1)} Projects
      </h1>

      <p class="mt-3 text-white/50">
        {projects.length} project{projects.length === 1 ? "" : "s"}
      </p>
    </div>

    <!-- Projects -->
    <div class="space-y-8">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Core>
