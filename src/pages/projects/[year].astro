---
import Core from "../../layouts/Core.astro";
import { getCollection } from "astro:content";
import Breadcrumb from "../../components/core/Breadcrumb.astro";
import ProjectCard from "../../components/ProjectCard.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  const years = [
    ...new Set(
      projects.map((project) =>
        new Date(project.data.date).getFullYear().toString(),
      ),
    ),
  ];

  return years.map((year) => ({
    params: { year },
    props: {
      year,
      projects: projects
        .filter(
          (project) =>
            new Date(project.data.date).getFullYear().toString() === year,
        )
        .sort(
          (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
        ),
    },
  }));
}

const { year, projects } = Astro.props;
---

<Core title={`Projects - ${year} | Huskey.cc`}>
  <section class="p-8 sm:p-12 md:p-16 lg:p-24 min-h-[75vh]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Sidebar -->
      <div class="lg:col-span-4 sticky lg:top-24 self-start">
        <!-- Breadcrumb -->
        <Breadcrumb
          items={[
            { label: "projects", href: "/projects" },
            { label: year, href: `/projects/${year}` },
          ]}
        />

        <!-- Title -->
        <h2
          class="mt-4 text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100"
        >
          {year}
        </h2>

        <!-- Description -->
        <p class="mt-6 text-base sm:text-lg text-white/50 leading-relaxed">
          Projects completed during {year}, including experiments, production
          work, and development iterations.
        </p>
      </div>

      <!-- Main -->
      <div class="lg:col-span-8 space-y-14">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</Core>
