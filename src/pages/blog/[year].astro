---
import Meta from '../../components/Meta.astro';
import Background from '../../components/Background.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	const years = [
		...new Set(
			posts.map((post) => new Date(post.data.date).getFullYear().toString()),
		),
	];

	return years.map((year) => ({
		params: { year },
		props: {
			year,
			posts: posts
				.filter(
					(post) => new Date(post.data.date).getFullYear().toString() === year,
				)
				.sort(
					(a, b) =>
						new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
				),
		},
	}));
}

const { year, posts } = Astro.props;
---

<html lang="en">
	<head>
		<Meta title={`Blog - ${year}`} />
	</head>

	<body class="relative bg-gray-900 text-gray-200">
		<Background />
		<Header />

		<section class="p-16 lg:p-24 min-h-[75vh]">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
				<!-- Left Column -->
				<div class="lg:col-span-4">
					<div
						class="text-xs sm:text-sm font-mono text-gray-400 uppercase tracking-wider"
					>
						<span class="mx-1 opacity-60">/</span>
						<a
							href="/blog"
							class="hover:text-white transition-colors duration-200"
						>
							blog
						</a>

						<span class="mx-1 opacity-60">/</span>

						<a
							href={`/blog/${year}`}
							class="hover:text-white transition-colors duration-200"
						>
							{year}
						</a>
					</div>

					<h2
						class="mt-4 text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100"
					>
						{year}
					</h2>

					<p class="mt-6 text-gray-400">
						Posts published in {year}
					</p>
				</div>

				<!-- Posts -->
				<div class="lg:col-span-8 space-y-8">
					{
						posts.map((post, index) => (
							<a
								href={`/blog/${post.slug}`}
								class="block p-6 md:p-8 bg-gray-800/20 rounded-2xl backdrop-blur-sm transition hover:bg-gray-800/40"
							>
								<span class="text-sm font-mono text-gray-400">
									{String(index + 1).padStart(2, '0')}
								</span>

								<h3 class="mt-2 text-2xl font-bold text-gray-100">
									{post.data.title}
								</h3>

								<p class="mt-2 text-sm font-mono text-gray-300">
									{new Date(post.data.date).toLocaleDateString('en-US', {
										month: 'short',
										day: 'numeric',
									})}
								</p>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
