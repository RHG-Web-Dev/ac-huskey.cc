---
import { siteConfig } from '../config';
import { Icon } from 'astro-icon/components';
const response = await fetch('https://rhgdev.in/@linkapi');
const links = await response.json();
---

<!-- <footer class="relative bg-gray-500/60 backdrop-blur-sm rounded-t-2xl"> --><!-- Fade from bottom to top with a gradient background and a blur effect, with a
rounded top border -->
<footer
	class="relative bg-linear-to-t from-gray-800/90 to-gray-500/10 backdrop-blur-2xl rounded-t-2xl"
>
	<div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
		<div
			class="flex flex-col md:flex-row md:items-center md:justify-between gap-8"
		>
			<div class="flex flex-col gap-4">
				<h3 class="text-2xl font-bold text-gray-100">
					{siteConfig.name}
				</h3>
				<p class="text-base text-gray-300">
					{siteConfig.title}
				</p>
				<div class="flex gap-5 pt-2">
					{
						Object.entries(links).map(([key, value], index) => {
							const link = value as { title: string; icon: string };
							return (
								<a
									href={`https://rhgdev.in/@${key}`}
									target="_blank"
									rel="noopener noreferrer"
									class="text-white hover:text-white/50 transition text-xl"
									aria-label={link.title}
								>
									<Icon name={`simple-icons:${link.icon}`} />
								</a>
							);
						})
					}
				</div>
			</div>

			<div class="md:flex hidden flex-col md:items-end gap-4">
				<p class="text-sm text-gray-200">
					© {new Date().getFullYear()}
					{siteConfig.name}.
				</p>
			</div>
		</div>
	</div>

	<!-- Back to Top Button -->
	<button
		id="back-to-top"
		class="opacity-0 fixed bottom-32 right-8 aspect-square rounded-xl bg-gray-800 text-white p-4 shadow-lg hover:bg-gray-600 transition-all duration-900"
		aria-label="Back to top"
	>
		↑
	</button>
</footer>

<script>
	const backToTop = document.getElementById('back-to-top');

	if (backToTop) {
		// Show button after scrolling 300px
		let updateBTTVisibility = () => {
			const scrollPosition = window.scrollY + window.innerHeight;
			const pageHeight = document.documentElement.scrollHeight;
			// show if the page is 150px larger than the viewport and the user has scrolled within 300px of the bottom
			if (pageHeight > window.innerHeight + 300 && scrollPosition > 300) {
				backToTop.classList.remove('opacity-0', 'translate-y-4');
				backToTop.classList.add('opacity-100', 'translate-y-0');
			} else {
				backToTop.classList.remove('opacity-100', 'translate-y-0');
				backToTop.classList.add('opacity-0', 'translate-y-4');
			}
		};

		window.addEventListener('scroll', updateBTTVisibility);
		window.addEventListener('resize', updateBTTVisibility);
		window.addEventListener('load', updateBTTVisibility);

		// Scroll to top smoothly
		backToTop.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	}
</script>
