---
import { siteConfig } from '../config';
import { Image } from 'astro:assets';
---

<header
	id="header"
	class="fixed top-0 left-3 right-3 z-50 h-16 transition-all duration-500 rounded-b-2xl"
>
	<nav class="mx-auto px-4 py-4 flex items-center">
		<!-- Logo -->
		<a href="/" class="flex items-center">
			<Image
				priority
				src="/img/favicon.png"
				alt="Logo"
				width="18"
				height="18"
				class="h-8 w-8 object-contain transform scale-125"
			/>
		</a>

		<!-- Desktop Links -->
		<ul class="hidden md:flex items-center gap-8 ml-16">
			{
				siteConfig.navBar.map((item) => (
					<li>
						<a
							href={item.link}
							class="text-gray-200 hover:text-gray-400 transition-colors"
						>
							{item.name}
						</a>
					</li>
				))
			}
		</ul>

		<!-- Desktop Connect Button -->
		<!-- <a
			href="https://connect.huskey.cc"
			class="hidden md:inline-block ml-auto px-4 py-2 rounded-lg bg-white/30 hover:bg-white/20 text-gray-100 transition backdrop-blur-sm"
		>
			Connect
		</a> -->

		<!-- Mobile Hamburger -->
		<button
			id="menu-btn"
			class="md:hidden ml-auto text-gray-200 text-4xl"
			aria-label="Toggle menu"
		>
			☰
		</button>
	</nav>

	<!-- Mobile Menu -->
	<div id="mobile-menu" class="hidden md:hidden bg-gray-500/90 rounded-2xl">
		<ul class="flex flex-col px-6 py-6 gap-6">
			{
				siteConfig.navBar.map((item) => (
					<li>
						<a
							href={item.link}
							class="text-gray-200 hover:text-gray-400 transition-colors font-medium"
						>
							{item.name}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</header>

<script>
	const menuBtn = document.getElementById('menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');

	// Close mobile menu when clicking outside or on scroll
	document.addEventListener('click', (event) => {
		const targetNode = event.target instanceof Node ? event.target : null;
		if (
			mobileMenu?.classList.contains('hidden') ||
			menuBtn?.contains(targetNode) ||
			mobileMenu?.contains(targetNode)
		) {
			return;
		}
		mobileMenu?.classList.add('hidden');
	});

	document.addEventListener('scroll', () => {
		if (!mobileMenu?.classList.contains('hidden')) {
			mobileMenu?.classList.add('hidden');
		}
	});

	menuBtn?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
	});

	// Change header background on scroll
	const scrollHandler = () => {
		const header = document.getElementById('header');
		if (window.scrollY > 50) {
			header?.classList.add('bg-gray-500/60', 'backdrop-blur-sm');
		} else {
			header?.classList.remove('bg-gray-500/60', 'backdrop-blur-sm');
		}
	};

	window.addEventListener('load', scrollHandler);
	window.addEventListener('scroll', scrollHandler);
</script>
