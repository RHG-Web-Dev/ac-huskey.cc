---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import { Icon } from "astro-icon/components";

const credentials = await getCollection("credentials");
credentials.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<section id="credentials" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2
          class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100"
        >
          Credentials
        </h2>
        <p class="mt-4 text-white/50 text-base sm:text-lg leading-relaxed">
          Over the years, I’ve earned various certifications that reflect my
          commitment to continuous learning and professional growth in the IT
          field.
        </p>
      </div>

      <div class="lg:col-span-8">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {
            credentials.map((item) => {
              const isClickable = !!item.data.url;
              const Tag = isClickable ? "a" : "div";
              return (
                <Tag
                  href={item.data.url}
                  target={isClickable ? "_blank" : undefined}
                  rel={isClickable ? "noopener noreferrer" : undefined}
                  class={`
      group relative
      bg-gray-800/20
      p-6
      text-center
      rounded-2xl
      aspect-square
      flex flex-col justify-center items-center
      backdrop-blur-sm
      border border-transparent

      transition-all duration-300

      ${
        isClickable
          ? `
            hover:bg-gray-800/40
            hover:-translate-y-1
            hover:border-white/10
            hover:shadow-lg
            hover:shadow-black/20
            cursor-pointer
          `
          : ""
      }
    `}
                >
                  {/* External Link Icon */}
                  {item.data.url && (
                    <div
                      class="absolute top-3 right-3
      opacity-0 translate-y-1
      transition-all duration-300
      group-hover:opacity-100
      group-hover:translate-y-0"
                    >
                      <Icon
                        name="mdi:arrow-top-right"
                        class="w-4 h-4 text-gray-400"
                      />
                    </div>
                  )}
                  <div class="flex justify-center mb-4">
                    <Picture
                      src={
                        item.data.badge.startsWith("http")
                          ? item.data.badge
                          : `/badges/${item.data.badge}`
                      }
                      alt="Icon"
                      class={`
  h-16 object-contain transition-transform duration-300
  ${isClickable ? "group-hover:scale-105" : ""}
`}
                      width="1080"
                      height="1080"
                    />
                  </div>

                  <h3 class="text-sm font-semibold text-gray-100">
                    {item.data.title}
                  </h3>

                  <p class="text-xs text-gray-300 mt-1">{item.data.issuer}</p>

                  <p class="text-xs text-gray-400 mt-1 font-mono">
                    {new Date(item.data.date).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                    })}
                    {item.data.expires
                      ? ` - ${new Date(item.data.expires).toLocaleDateString(
                          "en-US",
                          {
                            year: "numeric",
                            month: "short",
                          },
                        )}`
                      : ""}
                  </p>
                </Tag>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>
