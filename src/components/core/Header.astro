---
import { Image } from "astro:assets";

let navBar = [
  { name: "About", link: "/#about" },
  { name: "Credentials", link: "/#credentials" },
  { name: "Projects", link: "/#projects" },
  { name: "Contact", link: "/#contact" },
  { name: "Resume", link: "https://resume.huskey.cc" },
];
---

<header
  id="header"
  class="fixed top-0 left-3 right-3 z-10 h-16 transition-all duration-500 rounded-b-2xl"
>
  <nav class="mx-auto px-6 py-4 flex items-center">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <Image
        priority
        src="/img/favicon.png"
        alt="Logo"
        width="25"
        height="25"
        class="h-8 w-8 object-contain transform scale-150"
      />
    </a>

    <!-- Desktop Links -->
    <ul class="hidden md:flex items-center gap-8 ml-16">
      {
        navBar.slice(0, -1).map((item, index) => (
          <li class={index === navBar.length - 1 ? "ml-auto" : ""}>
            <a
              href={item.link}
              class="text-gray-200 hover:text-gray-400 transition-colors"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right Side Button -->
    <a
      href={navBar[navBar.length - 1].link}
      class="hidden md:inline-flex ml-auto px-4 py-2 rounded-xl bg-white/10 border border-white/10 hover:bg-white/20 text-gray-100 transition backdrop-blur-sm"
      target="_blank"
      rel="noopener noreferrer"
    >
      {navBar[navBar.length - 1].name}
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="menu-btn"
      class="md:hidden ml-auto text-gray-200"
      aria-label="Toggle menu"
    >
      <div class="space-y-1.5">
        <span class="block w-7 h-0.5 bg-white"></span>
        <span class="block w-7 h-0.5 bg-white"></span>
        <span class="block w-7 h-0.5 bg-white"></span>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-2 overflow-hidden rounded-2xl bg-gray-900/80 backdrop-blur-xl border border-white/10"
  >
    <ul class="flex flex-col p-4">
      {
        // navbar leave out last item for mobile CTA
        navBar.slice(0, -1).map((item) => (
          // navBar.map((item) => (
          <li>
            <a
              href={item.link}
              class="block rounded-xl px-4 py-3 text-gray-200 hover:bg-white/10 transition"
            >
              {item.name}
            </a>
          </li>
        ))
      }

      <!-- Mobile CTA -->
      <li class="pt-2">
        <a
          href={navBar[navBar.length - 1].link}
          class="block text-center rounded-xl px-4 py-3 bg-white/10 hover:bg-white/20 text-white transition"
          target="_blank"
          rel="noopener noreferrer"
        >
          {navBar[navBar.length - 1].name}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  const closeMenu = () => {
    mobileMenu?.classList.add("hidden");
  };

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close on outside click
  document.addEventListener("click", (event) => {
    const target = event.target as Node | null;

    if (
      mobileMenu?.classList.contains("hidden") ||
      menuBtn?.contains(target) ||
      mobileMenu?.contains(target)
    ) {
      return;
    }

    closeMenu();
  });

  // Close on scroll
  document.addEventListener("scroll", () => {
    closeMenu();
  });

  // Close on mobile link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  // Header background on scroll
  const scrollHandler = () => {
    const header = document.getElementById("header");

    if (window.scrollY > 50) {
      header?.classList.add(
        "bg-gray-900/60",
        "backdrop-blur-xl",
        "border-white/10",
      );
    } else {
      header?.classList.remove(
        "bg-gray-900/60",
        "backdrop-blur-xl",
        "border-white/10",
      );
    }
  };

  window.addEventListener("load", scrollHandler);
  window.addEventListener("scroll", scrollHandler);
</script>
