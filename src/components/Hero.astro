---
import { siteConfig } from '../config';
import { Icon } from 'astro-icon/components';
const response = await fetch('https://rhgdev.in/@linkapi');
const links = await response.json();
---

<div id="hero" class="relative isolate overflow-hidden py-24 md:h-screen">
	<!-- Gradient overlay -->
	<svg
		aria-hidden="true"
		class="absolute inset-0 -z-10 size-full stroke-gray-200 mask-[radial-gradient(85%_85%_at_top_right,rgb(255,255,255,25%),transparent)]"
	>
		<defs>
			<pattern
				x="50%"
				y={-1}
				id="grid-pattern"
				width={50}
				height={50}
				patternUnits="userSpaceOnUse"
			>
				<path d="M.5 200V.5H200" fill="none"></path>
			</pattern>
		</defs>
		<rect fill="url(#grid-pattern)" width="109%" height="100%" stroke-width={0}
		></rect>
	</svg>
	<div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
		<div class="space-y-4 sm:space-y-4">
			<img
				src="/profile.jpg"
				alt="Headshot"
				class="w-40 h-40 sm:w-52 sm:h-52 md:w-64 md:h-64 rounded-4xl object-cover animate-fade-in"
			/>

			<h1
				class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl tracking-tight text-gray-200 font-semibold animate-fade-in animation-delay-200"
			>
				{siteConfig.name}
			</h1>

			<p
				class="text-base sm:text-lg md:text-xl text-gray-300 animate-fade-in animation-delay-400"
			>
				{siteConfig.title}
			</p>

			<p
				class="text-base sm:text-lg md:text-xl text-gray-400 animate-fade-in animation-delay-600"
			>
				{siteConfig.location}
			</p>
			<div class="flex flex-wrap justify-left gap-6 mt-4">
				{
					Object.entries(links).map(([key, value], index) => {
						const link = value as { title: string; icon: string };
						return (
							<a
								href={`https://rhgdev.in/@${key}`}
								target="_blank"
								rel="noopener noreferrer"
								class="text-gray-400 hover:text-white transition text-2xl animate-fade-in opacity-0 "
								style={`animation-delay: ${1000 + index * 100}ms; animation-fill-mode: forwards;`}
								aria-label={link.title}
							>
								<Icon name={`simple-icons:${link.icon}`} />
							</a>
						);
					})
				}
			</div>
		</div>
	</div>
</div>

<style>
	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fadeIn 0.8s ease-out forwards;
		opacity: 0;
	}

	.animation-delay-200 {
		animation-delay: 0.2s;
	}

	.animation-delay-400 {
		animation-delay: 0.4s;
	}

	.animation-delay-600 {
		animation-delay: 0.6s;
	}
</style>
