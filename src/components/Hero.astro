---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
const response = await fetch("https://rhgdev.in/@linkapi");
const links = await response.json();
---

<div id="hero" class="relative isolate overflow-hidden py-24 md:h-screen">
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <!-- Dark gradient overlay for readability -->
    <div
      class="absolute inset-0 bg-linear-to-b from-black/40 via-black/20 to-transparent"
    >
    </div>

    <!-- Grid -->
    <svg class="absolute inset-0 h-full w-full opacity-10 rotate-5">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path
            d="M 60 0 L 0 0 0 60"
            fill="none"
            stroke="white"
            stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"></rect>
    </svg>

    <!-- Glow orbs -->
    <div
      class="absolute -top-60 -left-60 h-150 w-150 rounded-full bg-blue-900/30 blur-3xl"
    >
    </div>

    <div
      class="absolute top-40 -right-40 h-80 w-80 rounded-full bg-purple-700/30 blur-2xl animate-pulse [animation-delay:1s]"
    >
    </div>

    <div
      class="absolute bottom-10 left-1/2 h-40 w-40 -translate-x-1/2 rounded-full bg-cyan-400/20 blur-xl animate-pulse [animation-delay:2s]"
    >
    </div>
  </div>
  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div class="space-y-4 sm:space-y-4">
      <Image
        priority
        height="1080"
        width="1080"
        src="/img/profile.jpg"
        alt="Headshot"
        class="w-40 h-40 sm:w-52 sm:h-52 md:w-64 md:h-64 rounded-4xl object-cover animate-fade-in"
      />

      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl tracking-tight text-white font-semibold animate-fade-in"
        style="animation-delay: 0.2s;"
      >
        Rusty Huskey
      </h1>

      <p
        class="text-base sm:text-lg md:text-xl text-white/70 animate-fade-in"
        style="animation-delay: 0.4s;"
      >
        Computer IT Networking Graduate
      </p>

      <p
        class="text-base sm:text-lg md:text-xl text-white/50 animate-fade-in"
        style="animation-delay: 0.6s;"
      >
        Tennessee, USA
      </p>

      <!-- Buttons -->
      <div
        class="flex flex-wrap gap-4 mt-6 animate-fade-in"
        style="animation-delay: 0.8s;"
      >
        <!-- Primary: Contact -->
        <a
          href="#contact"
          class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-black font-semibold hover:bg-white/90 transition backdrop-blur-sm"
        >
          <Icon name="mdi:email" class="text-black/70 text-lg mr-2" />
          Contact Me
        </a>

        <!-- Secondary: Projects -->
        <a
          href="#projects"
          class="inline-flex items-center px-6 py-3 rounded-xl bg-white/10 border border-white/10 hover:bg-white/20 text-gray-100 transition backdrop-blur-sm"
        >
          <Icon name="mdi:folder-open" class="text-white/60 text-lg mr-2" />
          View Projects
        </a>

        <!-- Secondary: Credentials -->
        <a
          href="#credentials"
          class="inline-flex items-center px-6 py-3 rounded-xl bg-white/10 border border-white/10 hover:bg-white/20 text-gray-100 transition backdrop-blur-sm"
        >
          <Icon name="mdi:certificate" class="text-white/60 text-lg mr-2" />
          View Credentials
        </a>
      </div>
      <!-- <div class="flex flex-wrap justify-left gap-6 mt-4">
        {
          Object.entries(links).map(([key, value], index) => {
            const link = value as {
              title: string;
              icon: string;
              astroicon: string;
            };
            return (
              <a
                href={`https://rhgdev.in/@${key}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/40 hover:text-white transition text-2xl animate-fade-in opacity-0 drop-shadow-[0_0_2px_black]"
                style={`animation-delay: ${1000 + index * 100}ms; animation-fill-mode: forwards;`}
                aria-label={link.title}
              >
                <Icon name={link.astroicon} />
              </a>
            );
          })
        }
      </div> -->
      <!-- Bouncing arrow to prompt scrolling -->
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 animate-bounce">
        <Icon name="mdi:chevron-down" class="text-white/70 text-3xl" />
      </div>
    </div>
  </div>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.8s ease-out forwards;
      opacity: 0;
    }

    .animation-delay-200 {
      animation-delay: 0.2s;
    }

    .animation-delay-400 {
      animation-delay: 0.4s;
    }

    .animation-delay-600 {
      animation-delay: 0.6s;
    }
  </style>
</div>
