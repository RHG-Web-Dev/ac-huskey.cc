---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const projects = await getCollection("projects");

projects.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
    <!-- Left Content -->
    <div class="lg:col-span-4">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100"
      >
        Projects
      </h2>

      <p class="mt-4 text-white/50 text-base sm:text-lg leading-relaxed">
        Here are some of my recent projects. I enjoy working on a variety of IT
        and development projects, from personal experiments to collaborative
        efforts.
      </p>
    </div>

    <!-- Right Content -->
    <div class="lg:col-span-8">
      <!-- Tag Pills -->
      <div class="pt-4 pb-8">
        <div class="flex flex-wrap gap-2">
          {
            Array.from(
              new Set(projects.flatMap((project) => project.data.tags)),
            )
              .sort((a, b) => a.localeCompare(b))
              .map((tech) => (
                <a
                  href={`/projects/tags/${tech.toLowerCase()}`}
                  class="px-2.5 py-1 text-xs sm:text-sm
              rounded-md
              text-white/70
              bg-white/5
              border border-white/5

              transition-all duration-300
              hover:bg-white/10
              hover:border-white/10
              hover:text-white"
                >
                  {tech}
                </a>
              ))
          }
        </div>
      </div>

      <!-- Project Cards -->
      <div class="space-y-8">
        {
          projects
            .slice(0, 2)
            .map((project) => <ProjectCard project={project} />)
        }
      </div>

      <!-- Button -->
      <div class="pt-6 flex justify-center lg:justify-start">
        <a
          href="/projects"
          class="inline-block
            px-6 py-3
            text-lg sm:text-xl md:text-lg
            font-bold
            text-gray-100
            bg-gray-800/30
            border border-white/5
            rounded-xl
            transition-all duration-300
            hover:bg-gray-800/50
            hover:border-white/10
            hover:-translate-y-0.5
            hover:shadow-lg
            hover:shadow-black/20"
        >
          View All Projects
        </a>
      </div>
    </div>
  </div>
</section>
